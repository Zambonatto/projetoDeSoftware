				}
			senao se(nascimento == 19){
				fraseDaSorte = "A persistência é o caminho do êxito."
				}
			senao se(nascimento == 20){
				fraseDaSorte = "A compaixão é a linguagem universal do coração."
				}
			senao se(nascimento == 21){
