		escreva("\n\nInforme o dia do seu aniversário: ")
		leia(nascimento)
		
		se(nascimento > 0 e nascimento < 31){

			se(nascimento == 1){
				fraseDaSorte = "A vida trará coisas boas se você tiver paciência."
				}
			senao se(nascimento == 2){
				fraseDaSorte = "Demonstre amor e alegria em todas as oportunidades."
				}
			senao se(nascimento == 3){
				fraseDaSorte = "Não compense na ira o que lhe falta na razão."
				}
